#!/usr/bin/env bash
# Blocks direct pushes to main or dev.
# Install once: git config core.hooksPath .githooks

branch=$(git rev-parse --abbrev-ref HEAD)

if [[ "$branch" == "main" || "$branch" == "dev" ]]; then
  echo ""
  echo "  error: direct push to '$branch' is not allowed."
  echo "  Create a feature branch and open a PR to 'dev'."
  echo ""
  exit 1
fi
